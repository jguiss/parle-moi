# Signaling + API server URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# TURN server (optional, for production)
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USER=
NEXT_PUBLIC_TURN_PASS=

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# JWT secret (change in production!)
JWT_SECRET=parle-moi-secret-change-in-production

# SMTP for email verification (optional, uses ethereal.email in dev)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App URL for email links
APP_URL=http://localhost:3000
FROM_EMAIL=noreply@parle-moi.app
